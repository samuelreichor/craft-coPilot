{% import '_includes/forms.twig' as forms %}
{% from 'co-pilot/settings/_macros' import configWarning %}

<h3>{{ providerName }}</h3>

<div class="flex" style="gap: 24px;">
    <div style="flex: 3;">
        {{ forms.autosuggestField({
            label: 'API Key Environment Variable',
            instructions: 'The environment variable name containing your API key.',
            id: 'providerSettings-' ~ handle ~ '-apiKeyEnvVar',
            name: 'providerSettings[' ~ handle ~ '][apiKeyEnvVar]',
            value: config.apiKeyEnvVar ?? '',
            suggestEnvVars: true,
            placeholder: envPlaceholder,
            disabled: fileConfig.apiKeyEnvVar is defined,
            warning: fileConfig.apiKeyEnvVar is defined ? configWarning('providerSettings.' ~ handle ~ '.apiKeyEnvVar'),
            errors: [],
        }) }}
    </div>
    <div style="flex: 1;">
        {{ forms.selectField({
            label: 'Default Model',
            instructions: 'The default model for new chats.',
            id: 'providerSettings-' ~ handle ~ '-model',
            name: 'providerSettings[' ~ handle ~ '][model]',
            value: config.model ?? '',
            options: models|map(m => { label: m, value: m }),
            disabled: fileConfig.model is defined,
            warning: fileConfig.model is defined ? configWarning('providerSettings.' ~ handle ~ '.model'),
            errors: [],
        }) }}
    </div>
</div>
