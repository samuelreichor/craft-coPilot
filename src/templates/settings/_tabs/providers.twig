{% import '_includes/forms.twig' as forms %}
{% from 'co-pilot/settings/_macros' import configWarning %}

    {{ forms.selectField({
        label: 'Default Provider',
        instructions: 'Select the default AI provider.',
        id: 'defaultProvider',
        name: 'defaultProvider',
        value: settings.defaultProvider,
        options: providerOptions,
        disabled: config.defaultProvider is defined,
        warning: config.defaultProvider is defined ? configWarning('defaultProvider'),
        errors: settings.getErrors('defaultProvider'),
    }) }}

    {% for handle, provider in providers %}
        {% set html = provider.getSettingsHtml(
            settings.getProviderConfig(handle),
            config.providerSettings[handle] ?? {}
        ) %}
        {% if html|trim %}
            <hr>
            {{ html|raw }}
        {% endif %}
    {% endfor %}
