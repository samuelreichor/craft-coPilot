{% import '_includes/forms.twig' as forms %}

    <h3>Agent</h3>

    {{ forms.textField({
        label: 'Max Agent Iterations',
        instructions: 'Maximum number of tool call iterations per request.',
        id: 'maxAgentIterations',
        name: 'maxAgentIterations',
        value: settings.maxAgentIterations,
        type: 'number',
        min: 1,
        max: 50,
        errors: settings.getErrors('maxAgentIterations'),
    }) }}

    {{ forms.textField({
        label: 'Max Context Tokens',
        instructions: 'Maximum token budget for entry context sent to the AI.',
        id: 'maxContextTokens',
        name: 'maxContextTokens',
        value: settings.maxContextTokens,
        type: 'number',
        min: 1000,
        max: 128000,
        step: 1000,
        errors: settings.getErrors('maxContextTokens'),
    }) }}

    {{ forms.textField({
        label: 'Default Search Limit',
        instructions: 'Default number of results returned by search.',
        id: 'defaultSearchLimit',
        name: 'defaultSearchLimit',
        value: settings.defaultSearchLimit,
        type: 'number',
        min: 1,
        max: 100,
        errors: settings.getErrors('defaultSearchLimit'),
    }) }}

    <hr>

    <h3>Serialization</h3>

    {{ forms.textField({
        label: 'Default Serialization Depth',
        instructions: 'Default depth for nested entry serialization.',
        id: 'defaultSerializationDepth',
        name: 'defaultSerializationDepth',
        value: settings.defaultSerializationDepth,
        type: 'number',
        min: 1,
        max: 10,
        errors: settings.getErrors('defaultSerializationDepth'),
    }) }}

    {{ forms.textField({
        label: 'Max Serialization Depth',
        instructions: 'Maximum allowed serialization depth.',
        id: 'maxSerializationDepth',
        name: 'maxSerializationDepth',
        value: settings.maxSerializationDepth,
        type: 'number',
        min: 1,
        max: 10,
        errors: settings.getErrors('maxSerializationDepth'),
    }) }}

    <hr>

    <h3>Data Retention</h3>

    {{ forms.textField({
        label: 'Audit Log Retention (Days)',
        instructions: 'Number of days to keep audit log entries. Older entries are automatically deleted during garbage collection. Set to 0 to keep logs indefinitely.',
        id: 'auditLogRetentionDays',
        name: 'auditLogRetentionDays',
        value: settings.auditLogRetentionDays,
        type: 'number',
        min: 0,
        max: 365,
        errors: settings.getErrors('auditLogRetentionDays'),
    }) }}
